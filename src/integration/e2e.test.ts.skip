import { describe, it, expect, beforeEach, afterEach } from "vitest";
import { EvolutionEngine } from "../evolution/index.js";
import { Orchestrator } from "../orchestrator/index.js";
import { WorkflowEngine } from "../workflow/index.js";
import type { WorkflowDefinition } from "../workflow/types.js";
import { FileStateStore } from "../persistence/state-store.js";
import { FileMailboxManager } from "../mailbox/index.js";
import { TaskScheduler } from "../scheduler/index.js";
import { AgentIntegration } from "../agents/integration.js";
import { PiExperienceCollector } from "../agents/pi-experience-collector.js";
import { mkdir, rm } from "node:fs/promises";
import { tmpdir } from "node:os";
import { join } from "node:path";

describe("Multi-Agent E2E Integration", () => {
  let testDir: string;
  let stateStore: FileStateStore;
  let orchestrator: Orchestrator;
  let workflowEngine: WorkflowEngine;
  let mailboxManager: FileMailboxManager;
  let evolutionEngine: EvolutionEngine;
  let taskScheduler: TaskScheduler;
  let agentIntegration: AgentIntegration;
  let piCollector: PiExperienceCollector;

  beforeEach(async () => {
    testDir = join(tmpdir(), `openclaw-e2e-${Date.now()}`);
    await mkdir(testDir, { recursive: true });

    stateStore = new FileStateStore({ basePath: testDir });

    orchestrator = new Orchestrator({ stateStore });
    await orchestrator.initialize({
      maxAgents: 10,
      maxTasksPerAgent: 5,
      taskTimeout: 60000,
      heartbeatInterval: 10000,
      agentTimeout: 30000,
    });

    workflowEngine = new WorkflowEngine({ stateStore });
    await workflowEngine.initialize({});

    mailboxManager = new FileMailboxManager({ basePath: join(testDir, "mailboxes") });

    evolutionEngine = new EvolutionEngine({ stateStore });
    await evolutionEngine.initialize({
      enabled: true,
      evolutionInterval: 3600000,
      minExperiencesForEvolution: 5,
      minUsageForOptimization: 3,
      promptOptimizationEnabled: true,
      skillLearningEnabled: true,
      autoDeployThreshold: 0.8,
      maxCostPerEvolution: 1.0,
      cacheEnabled: true,
    });

    taskScheduler = new TaskScheduler({ stateStore });

    agentIntegration = new AgentIntegration("test-agent-001");
    agentIntegration.setOrchestrator(orchestrator);
    agentIntegration.setMailboxManager(mailboxManager);
    agentIntegration.setEvolutionEngine(evolutionEngine);
    agentIntegration.setStateStore(stateStore);

    piCollector = new PiExperienceCollector({ evolutionEngine });
  });

  afterEach(async () => {
    await orchestrator.shutdown();
    await workflowEngine.shutdown();
    await evolutionEngine.stop();
    await rm(testDir, { recursive: true, force: true });
  });

  describe("Agent Registration", () => {
    it("should register agent with orchestrator", async () => {
      await agentIntegration.registerWithOrchestrator({
        agentId: "test-agent-001",
        role: "worker",
        capabilities: ["code-generation", "testing"],
        maxConcurrentTasks: 2,
      });

      const agentManager = orchestrator.getAgentManager();
      const agent = await agentManager.getAgent("test-agent-001");

      expect(agent).toBeDefined();
      expect(agent?.role).toBe("worker");
      expect(agent?.capabilities).toContain("code-generation");
    });

    it("should unregister agent from orchestrator", async () => {
      await agentIntegration.registerWithOrchestrator({
        agentId: "test-agent-001",
        role: "worker",
        capabilities: ["test"],
      });

      await agentIntegration.unregisterFromOrchestrator();

      const agentManager = orchestrator.getAgentManager();
      const agent = await agentManager.getAgent("test-agent-001");

      expect(agent).toBeUndefined();
    });
  });

  describe("Mailbox Integration", () => {
    it("should create mailbox and send messages", async () => {
      await agentIntegration.setupMailbox({
        agentId: "test-agent-001",
      });

      const mailbox = await mailboxManager.getMailbox("test-agent-001");
      expect(mailbox).toBeDefined();
      expect(mailbox?.agentId).toBe("test-agent-001");
    });

    it("should send message to another agent", async () => {
      await mailboxManager.createMailbox("test-agent-002");

      await agentIntegration.setupMailbox({
        agentId: "test-agent-001",
      });

      await agentIntegration.sendMessage("test-agent-002", "direct", {
        content: "Hello from test-agent-001",
      });

      const messages = await mailboxManager.getMessages("test-agent-002");
      expect(messages).toHaveLength(1);
      expect(messages[0].from).toBe("test-agent-001");
    });
  });

  describe("Experience Collection", () => {
    it("should collect experience from session", async () => {
      const sessionId = `session-${Date.now()}`;

      await piCollector.handleEvent({
        type: "session_start",
        sessionId,
        agentId: "test-agent-001",
        prompt: "Write a hello world program",
        systemPrompt: "You are a helpful coding assistant",
        tools: ["read", "write", "bash"],
        model: "claude-sonnet-4",
      });

      await piCollector.handleEvent({
        type: "tool_call",
        sessionId,
        tool: "write",
        input: { path: "/tmp/hello.ts", content: 'console.log("Hello, World!")' },
        output: { success: true },
        duration: 100,
        success: true,
      });

      await piCollector.handleEvent({
        type: "session_end",
        sessionId,
        status: "success",
        tokensUsed: 500,
        duration: 2000,
        userInterventions: 0,
      });

      const state = piCollector.getSessionState(sessionId);
      expect(state).toBeUndefined();

      expect(piCollector.getActiveSessionCount()).toBe(0);
    });

    it("should track tool calls in experience", async () => {
      const sessionId = `session-${Date.now()}`;

      await piCollector.handleEvent({
        type: "session_start",
        sessionId,
        agentId: "test-agent-001",
        prompt: "Test prompt",
        tools: [],
        model: "test-model",
      });

      await piCollector.handleEvent({
        type: "tool_call",
        sessionId,
        tool: "bash",
        input: { command: "echo test" },
        output: "test\n",
        duration: 50,
        success: true,
      });

      await piCollector.handleEvent({
        type: "tool_call",
        sessionId,
        tool: "read",
        input: { path: "/tmp/test.txt" },
        error: "File not found",
        success: false,
      });

      const state = piCollector.getSessionState(sessionId);
      expect(state?.toolCalls).toHaveLength(2);
      expect(state?.toolCalls[0].tool).toBe("bash");
      expect(state?.toolCalls[1].success).toBe(false);

      await piCollector.handleEvent({
        type: "session_end",
        sessionId,
        status: "partial",
        tokensUsed: 100,
        duration: 1000,
        userInterventions: 1,
      });
    });
  });

  describe("Task Scheduling", () => {
    it("should submit and process task", async () => {
      await agentIntegration.registerWithOrchestrator({
        agentId: "test-agent-001",
        role: "worker",
        capabilities: ["general"],
      });

      const taskId = await orchestrator.submitTask({
        type: "code-generation",
        priority: "normal",
        payload: { prompt: "Write a function" },
        requiredCapabilities: ["general"],
      });

      expect(taskId).toBeDefined();

      const task = await orchestrator.getTaskStatus(taskId);
      expect(task).toBeDefined();
      expect(task?.status).toBe("pending");
    });
  });

  describe("Workflow Execution", () => {
    it("should execute workflow", async () => {
      const definition: WorkflowDefinition = {
        id: "test-workflow-1",
        name: "Test Workflow",
        nodes: [
          { id: "step-1", type: "task", name: "Initialize", config: { action: "init" } },
          { id: "step-2", type: "task", name: "Process", config: { action: "process" }, dependencies: ["step-1"] },
          { id: "step-3", type: "task", name: "Finalize", config: { action: "finalize" }, dependencies: ["step-2"] },
        ],
        edges: [
          { from: "step-1", to: "step-2" },
          { from: "step-2", to: "step-3" },
        ],
      };

      const result = await workflowEngine.execute(definition);

      expect(result).toBeDefined();
      expect(["completed", "failed"]).toContain(result.status);
    });
  });

  describe("Evolution Cycle", () => {
    it("should run evolution cycle", async () => {
      for (let i = 0; i < 5; i++) {
        const sessionId = `session-${i}-${Date.now()}`;

        await evolutionEngine.collectExperience({
          taskId: sessionId,
          agentType: "test-agent-001",
          prompt: `Test prompt ${i}`,
          systemPrompt: "",
          tools: ["bash", "read"],
          model: "test-model",
          steps: [],
          toolCalls: [{ tool: "bash", input: {}, output: {}, timestamp: Date.now(), success: true }],
          decisions: [],
          errors: [],
          recoveries: [],
          outcome: {
            status: i % 2 === 0 ? "success" : "partial",
            tokensUsed: 100 * (i + 1),
            duration: 1000 * (i + 1),
            userInterventions: 0,
          },
        });
      }

      const report = await evolutionEngine.runEvolutionCycle();

      expect(report).toBeDefined();
      expect(report.experiences.collected).toBeGreaterThanOrEqual(0);
      expect(["completed", "failed"]).toContain(report.status);
    });
  });
});
